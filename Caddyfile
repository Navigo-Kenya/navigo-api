{
    # Désactive l'API d'administration de Caddy en production
    admin off

    # Email pour votre compte Let's Encrypt / ACME
    email admin@hopln.app
}

# Uniquement le moteur API Laravel (Hébergé sur Hetzner)
api.navigo.co.ke {
    # Racine publique de Laravel dans votre conteneur Docker
    root * /var/www/public

    # Compression des réponses (indispensable pour économiser la data mobile au Kenya)
    encode zstd gzip

    # En-têtes de sécurité optimisés pour une API de transport
    header {
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        # IMPORTANT : On autorise explicitement la géolocalisation pour votre API
        Permissions-Policy "geolocation=(self), camera=(), microphone=()"
        -Server
    }

    # Proxy vers le conteneur PHP-FPM de votre application Laravel
    php_fastcgi app:9000 {
        # Liste officielle des blocs d'adresses IP de Cloudflare (obligatoire avec le proxy Cloudflare)
        trusted_proxies static 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22

        # Augmentation des timeouts à 45s pour les calculs d'itinéraires de transport lourds
        read_timeout 45s
        write_timeout 45s
    }

    # Journalisation des accès au format JSON structuré
    log {
        output file /var/log/caddy/api.log {
            roll_size    50mb
            roll_keep    5
            roll_keep_for 720h
        }
        format json
    }
}
